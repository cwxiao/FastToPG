  "load_template": "mysql_to_pg.load",
  "source": {
    "type": "mysql",
    "uri": "mysql://syncuser:sync123456@192.168.1.67:3306/{{DB_NAME}}"
  },
  "target": {
    "uri": "postgresql://postgres:spxxWYZdev123@192.168.1.121:5432/{{DB_NAME}}",
    "psql_container": "postgres16"
  },
  "mysql": {
    "container": "mysql8",
    "user": "root",
    "password": "123456"
  },
  "pgloader": {
    "image": "dimitri/pgloader:v3.6.7",
    "env": {
      "PGLOADER_DYNSIZE": "4GB",
      "SBCL_DYNAMIC_SPACE_SIZE": "8192"
    },
    "clear_public_before_sync": true,
    "show_output": true
  },
  "datax": {
    "enabled": true,
    "home": "datax/datax",
    "python": "python",
    "jvm": "-Xms2g -Xmx6g -XX:+UseG1GC -XX:+HeapDumpOnOutOfMemoryError",
    "loglevel": "warn",
    "source_uri": "mysql://syncuser:sync123456@192.168.1.67:3306/{{DB_NAME}}",
    "mysql_jdbc_params": "useSSL=false",
    "target_table_lowercase": true,
    "target_column_lowercase": true,
    "table_parallelism": 7,
    "channel": 4,
    "batch_size": 2000,
    "job_dir": ".datax_jobs",
    "cleanup_jobs_on_finish": true,
    "show_output": true,
    "compact_log": true,
    "exclude_table_keywords": [],
    "log_retention_days": 7,
    "log_dirs": [
      "datax/datax/log",
      "datax/datax/log_perf"
    ],
    "env": {}
  }
}